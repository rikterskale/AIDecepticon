# Auto-detect text files, with explicit endings for cross-platform project files.
* text=auto

.gitattributes text eol=lf
.gitignore text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf

*.ps1 text eol=crlf
